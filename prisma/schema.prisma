// =============================================================================
// 教育培训机构全流程管理平台 — Prisma Schema
// 版本: v1.0
// 数据库: SQLite
// 注意: SQLite不支持enum，所有状态字段使用String类型
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Phase 1 Tables
// =============================================================================

model Tenant {
  id                    String   @id @default(cuid())
  name                  String
  logo                  String?
  contactPhone          String?
  contactEmail          String?
  address               String?
  status                String   @default("active")   // active | suspended | expired
  subscriptionPlan      String   @default("starter")  // starter | professional | enterprise
  subscriptionExpiresAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users          User[]
  courses        Course[]
  orders         Order[]
  fundingTypes   FundingType[]
  certificates   Certificate[]
  notifications  Notification[]
  discountRules  DiscountRule[]
  classrooms     Classroom[]

  @@map("tenant")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  role         String   // editor | desk | trainer | learner
  phone        String?
  email        String?
  passwordHash String
  displayName  String
  avatar       String?
  parentId     String?
  status       String   @default("active")  // active | disabled
  registeredAt DateTime @default(now())
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  parent   User?  @relation("UserBinding", fields: [parentId], references: [id])
  children User[] @relation("UserBinding")

  ordersAsBuyer        Order[]              @relation("OrderBuyer")
  ordersAsOperator     Order[]              @relation("OrderOperator")
  enrollments          Enrollment[]
  attendanceRecords    Attendance[]         @relation("AttendanceUser")
  attendanceMarked     Attendance[]         @relation("AttendanceMarker")
  certificates         Certificate[]        @relation("CertificateUser")
  revokedCertificates  Certificate[]        @relation("CertificateRevoker")
  fundingApplications  FundingApplication[] @relation("FundingAppUser")
  reviewedApplications FundingApplication[] @relation("FundingAppReviewer")
  notifications        Notification[]
  coursesCreated       Course[]
  schedulesAsTrainer   Schedule[]
  assessmentsCreated   Assessment[]
  gradesReceived       Grade[]              @relation("GradeLearner")
  gradesGiven          Grade[]              @relation("GradeGrader")
  refundsApproved      Refund[]             @relation("RefundApprover")

  @@unique([tenantId, phone])
  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("user")
}

model Course {
  id            String    @id @default(cuid())
  tenantId      String
  title         String
  description   String?
  coverImageUrl String?
  category      String?
  type          String    @default("offline")  // online | offline | hybrid
  basePrice     Int       @default(0)
  status        String    @default("draft")    // draft | published | archived
  publishedAt   DateTime?
  archivedAt    DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  creator         User             @relation(fields: [createdBy], references: [id])
  schedules       Schedule[]
  courseFundings  CourseFunding[]
  certificates    Certificate[]

  @@index([tenantId, status])
  @@index([tenantId, category])
  @@map("course")
}

model Schedule {
  id                   String    @id @default(cuid())
  courseId             String
  classroomId          String?
  trainerId            String?
  title                String
  startTime            DateTime
  endTime              DateTime
  capacity             Int       @default(20)
  enrolledCount        Int       @default(0)
  registrationDeadline DateTime?
  price                Int?
  meetingLink          String?
  status               String    @default("draft")  // draft | open | full | cancelled | completed
  cancellationReason   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  course       Course        @relation(fields: [courseId], references: [id])
  classroom    Classroom?    @relation(fields: [classroomId], references: [id])
  trainer      User?         @relation(fields: [trainerId], references: [id])
  enrollments  Enrollment[]
  attendances  Attendance[]
  orderItems   OrderItem[]
  assessments  Assessment[]
  certificates Certificate[]

  @@index([courseId, status])
  @@index([startTime])
  @@map("schedule")
}

model Classroom {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  capacity  Int      @default(30)
  location  String?
  status    String   @default("active")  // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  schedules Schedule[]

  @@index([tenantId])
  @@map("classroom")
}

model Enrollment {
  id         String   @id @default(cuid())
  scheduleId String
  userId     String
  orderId    String
  status     String   @default("active")  // active | transferred | refunded | dropped
  enrolledAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  schedule Schedule @relation(fields: [scheduleId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])

  @@unique([scheduleId, userId])
  @@index([userId])
  @@index([orderId])
  @@map("enrollment")
}

model Order {
  id             String    @id @default(cuid())
  tenantId       String
  orderNumber    String    @unique
  buyerId        String
  operatorId     String
  channel        String    @default("online")  // online | desk | b2b
  originalAmount Int       @default(0)
  discountAmount Int       @default(0)
  payableAmount  Int       @default(0)
  paidAmount     Int       @default(0)
  status         String    @default("pending") // pending | paid | partial_refunded | refunded | cancelled | expired
  expiresAt      DateTime?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  buyer               User                 @relation("OrderBuyer", fields: [buyerId], references: [id])
  operator            User                 @relation("OrderOperator", fields: [operatorId], references: [id])
  orderItems          OrderItem[]
  payments            Payment[]
  refunds             Refund[]
  enrollments         Enrollment[]
  fundingApplications FundingApplication[]

  @@index([tenantId, status])
  @@index([buyerId])
  @@index([orderNumber])
  @@map("order")
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  scheduleId     String
  unitPrice      Int      @default(0)
  quantity       Int      @default(1)
  discountDetail String?  // JSON
  createdAt      DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id])
  schedule Schedule @relation(fields: [scheduleId], references: [id])

  @@index([orderId])
  @@index([scheduleId])
  @@map("order_item")
}

model Payment {
  id            String    @id @default(cuid())
  orderId       String
  paymentMethod String    // wechat | alipay | cash | transfer
  transactionId String    @unique
  amount        Int       @default(0)
  currency      String    @default("CNY")
  status        String    @default("pending")  // pending | success | failed
  callbackRaw   String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payment")
}

model Attendance {
  id            String    @id @default(cuid())
  scheduleId    String
  userId        String
  status        String    @default("present")  // present | absent | late | early_leave | excused
  checkInMethod String    @default("manual")   // scan | qrcode | manual | gps
  checkInTime   DateTime?
  checkOutTime  DateTime?
  markedBy      String?
  createdAt     DateTime  @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id])
  user     User     @relation("AttendanceUser", fields: [userId], references: [id])
  marker   User?    @relation("AttendanceMarker", fields: [markedBy], references: [id])

  @@index([scheduleId, userId])
  @@index([userId])
  @@map("attendance")
}

// =============================================================================
// Phase 2 Tables
// =============================================================================

model FundingType {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  source          String    // government | enterprise | scholarship | nonprofit
  calculationRule String    // fixed_per_head | percentage | conditional
  amountOrRate    Int       @default(0)
  maxAmount       Int?
  budgetLimit     Int       @default(0)
  budgetUsed      Int       @default(0)
  effectiveFrom   DateTime
  effectiveTo     DateTime
  status          String    @default("active")  // active | expired | depleted
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  courseFundings      CourseFunding[]
  fundingApplications FundingApplication[]

  @@index([tenantId, status])
  @@map("funding_type")
}

model CourseFunding {
  id            String   @id @default(cuid())
  courseId      String
  fundingTypeId String
  applicable    Boolean  @default(true)
  createdAt     DateTime @default(now())

  course      Course      @relation(fields: [courseId], references: [id])
  fundingType FundingType @relation(fields: [fundingTypeId], references: [id])

  @@unique([courseId, fundingTypeId])
  @@map("course_funding")
}

model FundingApplication {
  id             String    @id @default(cuid())
  fundingTypeId  String
  userId         String
  orderId        String
  amountApplied  Int       @default(0)
  amountApproved Int?
  status         String    @default("pending")  // pending | approved | rejected | disbursed
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewComment  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  fundingType FundingType @relation(fields: [fundingTypeId], references: [id])
  user        User        @relation("FundingAppUser", fields: [userId], references: [id])
  order       Order       @relation(fields: [orderId], references: [id])
  reviewer    User?       @relation("FundingAppReviewer", fields: [reviewedBy], references: [id])

  @@index([userId, status])
  @@index([fundingTypeId, status])
  @@map("funding_application")
}

model Refund {
  id           String    @id @default(cuid())
  orderId      String
  refundAmount Int       @default(0)
  refundType   String    @default("full")      // full | partial
  reason       String?
  status       String    @default("pending")   // pending | approved | processed | rejected
  approvedBy   String?
  refundedAt   DateTime?
  createdAt    DateTime  @default(now())

  order    Order @relation(fields: [orderId], references: [id])
  approver User? @relation("RefundApprover", fields: [approvedBy], references: [id])

  @@index([orderId])
  @@map("refund")
}

// =============================================================================
// Phase 3 Tables
// =============================================================================

model Certificate {
  id                String    @id @default(cuid())
  tenantId          String
  certificateNumber String    @unique
  userId            String
  courseId          String
  scheduleId        String
  issueDate         DateTime
  expiryDate        DateTime?
  templateId        String?
  metadataJson      String?
  status            String    @default("issued")  // issued | revoked
  revokedAt         DateTime?
  revokedBy         String?
  revokeReason      String?
  createdAt         DateTime  @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  user     User     @relation("CertificateUser", fields: [userId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  schedule Schedule @relation(fields: [scheduleId], references: [id])
  revoker  User?    @relation("CertificateRevoker", fields: [revokedBy], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([certificateNumber])
  @@map("certificate")
}

model Assessment {
  id          String    @id @default(cuid())
  scheduleId  String
  createdBy   String
  title       String
  description String?
  type        String    @default("exam")    // exam | assignment | quiz
  totalScore  Int       @default(100)
  passScore   Int       @default(60)
  dueDate     DateTime?
  status      String    @default("draft")   // draft | open | closed
  createdAt   DateTime  @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id])
  creator  User     @relation(fields: [createdBy], references: [id])
  grades   Grade[]

  @@index([scheduleId])
  @@map("assessment")
}

model Grade {
  id           String    @id @default(cuid())
  assessmentId String
  userId       String
  score        Int       @default(0)
  result       String    @default("fail")   // pass | fail
  feedback     String?
  gradedBy     String
  gradedAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  learner    User       @relation("GradeLearner", fields: [userId], references: [id])
  grader     User       @relation("GradeGrader", fields: [gradedBy], references: [id])

  @@unique([assessmentId, userId])
  @@map("grade")
}

model Notification {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  eventType  String
  title      String
  content    String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  channel    String    @default("in_app")   // in_app | email | sms
  sendStatus String    @default("sent")     // pending | sent | failed
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([tenantId, eventType])
  @@map("notification")
}

model MockSms {
  id           String   @id @default(cuid())
  phone        String
  content      String
  templateCode String?
  status       String   @default("sent")    // sent | failed
  createdAt    DateTime @default(now())

  @@map("mock_sms")
}

model MockEmail {
  id        String   @id @default(cuid())
  toEmail   String
  subject   String
  bodyHtml  String
  status    String   @default("sent")       // sent | failed
  createdAt DateTime @default(now())

  @@map("mock_email")
}

model DiscountRule {
  id            String    @id @default(cuid())
  tenantId      String
  type          String    // coupon | group_buy | early_bird | flash_sale
  code          String?
  ruleConfig    String    // JSON
  usageLimit    Int       @default(0)
  usageCount    Int       @default(0)
  effectiveFrom DateTime
  effectiveTo   DateTime
  status        String    @default("active")  // active | paused | expired
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([code])
  @@index([tenantId, status])
  @@map("discount_rule")
}
